---
import { readFileSync } from "node:fs";
import { resolve } from "node:path";
import * as d3 from "d3";
import { loadDidCi } from "@/lib/data";

// Load the strata CSV at build time
const path = resolve("public/data/distributive_strata.csv");
const lines = readFileSync(path, "utf-8").trim().split("\n");
const headers = lines[0].split(",");
const idx = {
  variable: headers.indexOf("variable"),
  tertile_label: headers.indexOf("tertile_label"),
  n_cordon: headers.indexOf("n_cordon"),
  gap_pp: headers.indexOf("gap_pp"),
  gap_ci_lo: headers.indexOf("gap_ci_lo"),
  gap_ci_hi: headers.indexOf("gap_ci_hi"),
};
interface Row {
  variable: string;
  tertile_label: string;
  n_cordon: number;
  gap_pp: number | null;
  gap_ci_lo: number | null;
  gap_ci_hi: number | null;
}
const allRows: Row[] = lines.slice(1).map((l) => {
  const f = l.split(",");
  const num = (s: string) => (s === "" ? null : parseFloat(s));
  return {
    variable: f[idx.variable],
    tertile_label: f[idx.tertile_label].replace(/^"|"$/g, ""),
    n_cordon: parseInt(f[idx.n_cordon], 10),
    gap_pp:    num(f[idx.gap_pp]),
    gap_ci_lo: num(f[idx.gap_ci_lo]),
    gap_ci_hi: num(f[idx.gap_ci_hi]),
  };
});

// Group definitions
const groups = [
  { variable: "median_hh_income",      label: "Neighborhood income" },
  { variable: "pct_no_vehicle",        label: "How car-free the neighborhood is" },
  { variable: "pct_transit_commute",   label: "How transit-reliant the neighborhood is" },
];

const ci = loadDidCi();
const refCitywide = ci.realGap.value;
const refDiD = ci.didOfDids.value;

// Layout
const W = 920;
const ROW_H = 40;
const GROUP_GAP = 24;
const M = { top: 24, right: 140, bottom: 56, left: 240 };
const innerW = W - M.left - M.right;
const totalRows = groups.length * 3;
const innerH = totalRows * ROW_H + (groups.length - 1) * GROUP_GAP;
const H = innerH + M.top + M.bottom;

// X scale — domain covers all values + reference lines, with padding
const allValues: number[] = [];
allRows.forEach((r) => {
  if (r.gap_pp !== null) allValues.push(r.gap_pp);
  if (r.gap_ci_lo !== null) allValues.push(r.gap_ci_lo);
  if (r.gap_ci_hi !== null) allValues.push(r.gap_ci_hi);
});
allValues.push(refCitywide, refDiD, 0);
const dom: [number, number] = [d3.min(allValues) ?? -5, d3.max(allValues) ?? 0];
const span = dom[1] - dom[0];
const x = d3.scaleLinear()
  .domain([dom[0] - span * 0.06, dom[1] + span * 0.06])
  .range([0, innerW])
  .nice();

const xTicks = x.ticks(5);
const fmt = (v: number) => `${v >= 0 ? "+" : "−"}${Math.abs(v).toFixed(1)}`;

// Per-row Y position
function rowY(groupIdx: number, tertileIdx: number): number {
  return groupIdx * (3 * ROW_H + GROUP_GAP) + tertileIdx * ROW_H + ROW_H / 2;
}
---
<figure class="strata-figure">
  <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-labelledby="strata-title strata-desc"
       preserveAspectRatio="xMidYMid meet">
    <title id="strata-title">Cordon-vs-rest gap in NO₂ change, by demographic tertile</title>
    <desc id="strata-desc">
      Each row compares the congestion zone to a group of similar
      neighborhoods elsewhere in NYC. Bars show how much more the zone's
      air improved than that group's, with 95% bootstrap confidence
      intervals.
    </desc>

    <g transform={`translate(${M.left},${M.top})`}>

      {/* X gridlines + ticks */}
      {xTicks.map((t) => (
        <g class="grid">
          <line x1={x(t)} x2={x(t)} y1={0} y2={innerH} />
          <text x={x(t)} y={innerH + 18} class="tick" text-anchor="middle">{`${fmt(t)} pp`}</text>
        </g>
      ))}

      {/* Reference lines */}
      <g class="ref-line ref-citywide">
        <line x1={x(refCitywide)} x2={x(refCitywide)} y1={-8} y2={innerH} />
        <text x={x(refCitywide)} y={-12} class="ref-label" text-anchor="middle">Citywide · {fmt(refCitywide)} pp</text>
      </g>
      <g class="ref-line ref-did">
        <line x1={x(refDiD)} x2={x(refDiD)} y1={-8} y2={innerH} />
        <text x={x(refDiD)} y={-12} class="ref-label" text-anchor="middle">After background drift · {fmt(refDiD)} pp</text>
      </g>

      {/* Group separators */}
      {groups.slice(1).map((_, gi) => {
        const y = (gi + 1) * (3 * ROW_H + GROUP_GAP) - GROUP_GAP / 2;
        return <line x1={-M.left + 16} x2={innerW} y1={y} y2={y} class="group-divider" />;
      })}

      {/* Group labels (left margin) */}
      {groups.map((g, gi) => {
        const y = gi * (3 * ROW_H + GROUP_GAP) + (3 * ROW_H) / 2;
        return (
          <text x={-M.left + 16} y={y} class="group-label" dominant-baseline="middle">
            {g.label}
          </text>
        );
      })}

      {/* Rows */}
      {groups.map((g, gi) => {
        const groupRows = allRows.filter((r) => r.variable === g.variable);
        return groupRows.slice(0, 3).map((r, ti) => {
          const yc = rowY(gi, ti);
          const hasData = r.gap_pp !== null && r.gap_ci_lo !== null && r.gap_ci_hi !== null;
          const isImprove = hasData && r.gap_pp! < 0;
          const fill = isImprove ? "var(--improve)" : "var(--zone)";
          return (
            <g class="strata-row">
              {/* Tertile label, sitting just inside the chart area */}
              <text x={-12} y={yc} class="tertile-label" text-anchor="end" dominant-baseline="middle">
                {r.tertile_label}
              </text>
              {hasData ? (
                <>
                  <line x1={x(r.gap_ci_lo!)} x2={x(r.gap_ci_hi!)} y1={yc} y2={yc} class="ci-bar" stroke={fill} />
                  <line x1={x(r.gap_ci_lo!)} x2={x(r.gap_ci_lo!)} y1={yc - 5} y2={yc + 5} class="ci-cap" stroke={fill} />
                  <line x1={x(r.gap_ci_hi!)} x2={x(r.gap_ci_hi!)} y1={yc - 5} y2={yc + 5} class="ci-cap" stroke={fill} />
                  <circle cx={x(r.gap_pp!)} cy={yc} r="5" fill={fill} stroke="var(--bg)" stroke-width="1.5" />
                  <text x={innerW + 10} y={yc} class="row-value" dominant-baseline="middle">
                    {fmt(r.gap_pp!)} pp
                  </text>
                </>
              ) : (
                <text x={x(0)} y={yc} class="empty-label" dominant-baseline="middle">
                  no congestion-zone neighborhoods in this group
                </text>
              )}
            </g>
          );
        });
      }).flat()}

      {/* X-axis label */}
      <text x={innerW / 2} y={innerH + 44} class="axis-label" text-anchor="middle">
        How much more the congestion zone's air improved (percentage points)
      </text>
    </g>
  </svg>
</figure>

<style>
  .strata-figure {
    margin: var(--s-5) auto;
    max-width: 1080px;
  }
  .strata-figure svg { width: 100%; height: auto; display: block; }

  .grid line {
    stroke: var(--rule);
    stroke-width: 0.5;
    stroke-dasharray: 2 4;
  }
  .tick {
    font-family: var(--font-mono);
    font-size: 12px;
    fill: var(--ink-faint);
  }
  .axis-label {
    font-family: var(--font-mono);
    font-size: 13px;
    fill: var(--ink-muted);
    letter-spacing: 0.04em;
  }

  .ref-line line {
    stroke-width: 1;
    stroke-dasharray: 4 4;
  }
  .ref-citywide line { stroke: var(--ink-muted); }
  .ref-did line { stroke: var(--zone); }
  .ref-label {
    font-family: var(--font-mono);
    font-size: 11px;
    fill: var(--ink-faint);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .ref-citywide .ref-label { fill: var(--ink-muted); }
  .ref-did .ref-label { fill: var(--zone); }

  .group-divider {
    stroke: var(--rule);
    stroke-width: 0.5;
  }
  .group-label {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 500;
    fill: var(--ink);
  }
  .tertile-label {
    font-family: var(--font-mono);
    font-size: 13px;
    fill: var(--ink-muted);
  }
  .ci-bar { stroke-width: 2; }
  .ci-cap { stroke-width: 1.5; }
  .row-value {
    font-family: var(--font-mono);
    font-size: 13px;
    fill: var(--ink);
    font-feature-settings: "tnum" 1;
  }
  .empty-label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 12px;
    fill: var(--ink-faint);
  }
</style>
