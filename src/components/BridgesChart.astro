---
import { readFileSync } from "node:fs";
import { resolve } from "node:path";
import * as d3 from "d3";

interface Row {
  window: string;
  label: string;
  meanPerDay: number;
  ciLo: number;
  ciHi: number;
}

const lines = readFileSync(resolve("public/data/bridges_did.csv"), "utf-8").trim().split("\n");

// CSV header: window, label, n_days, total_vehicles, mean_per_day, ci95_lo, ci95_hi
// label is quoted because it contains commas. After the quoted label, the
// remaining numeric columns are: n_days, total_vehicles, mean_per_day, ci95_lo, ci95_hi.
const rows: Row[] = lines.slice(1).map((l) => {
  const m = l.match(/^([^,]*),"([^"]*)",(.+)$/);
  if (!m) throw new Error(`Failed to parse bridges row: ${l}`);
  const rest = m[3].split(",");
  return {
    window: m[1],
    label: m[2],
    meanPerDay: parseFloat(rest[2]),   // mean_per_day (was incorrectly rest[1])
    ciLo:       parseFloat(rest[3]),   // ci95_lo
    ciHi:       parseFloat(rest[4]),   // ci95_hi
  };
});

const realPre  = rows.find((r) => r.window === "real_pre")!;
const realPost = rows.find((r) => r.window === "real_post")!;
const placPre  = rows.find((r) => r.window === "placebo_pre")!;
const placPost = rows.find((r) => r.window === "placebo_post")!;

const realPct = ((realPost.meanPerDay - realPre.meanPerDay) / realPre.meanPerDay) * 100;
const placPct = ((placPost.meanPerDay - placPre.meanPerDay) / placPre.meanPerDay) * 100;
const did = realPct - placPct;

const W = 760;
const H = 360;
const M = { top: 32, right: 24, bottom: 56, left: 80 };
const innerW = W - M.left - M.right;
const innerH = H - M.top - M.bottom;

const groups = [
  { key: "real",    label: "Real comparison",   pre: realPre, post: realPost, pct: realPct },
  { key: "placebo", label: "Placebo (no policy)", pre: placPre, post: placPost, pct: placPct },
];

const yMin = 0.86 * 1e6;
const yMax = 0.96 * 1e6;
const y = d3.scaleLinear().domain([yMin, yMax]).range([innerH, 0]);

const groupBand = d3.scaleBand()
  .domain(groups.map((g) => g.key))
  .range([0, innerW])
  .padding(0.20);

const barBand = d3.scaleBand()
  .domain(["pre", "post"])
  .range([0, groupBand.bandwidth()])
  .padding(0.30);

const yTicks = y.ticks(5);
const fmtVal = (v: number) => `${(v / 1e6).toFixed(2)}M`;
const fmtPct = (v: number) => `${v >= 0 ? "+" : "−"}${Math.abs(v).toFixed(2)}%`;
const fmtPP  = (v: number) => `${v >= 0 ? "+" : "−"}${Math.abs(v).toFixed(2)} pp`;
---
<figure class="bridges-figure">
  <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-labelledby="bridges-title bridges-desc"
       preserveAspectRatio="xMidYMid meet">
    <title id="bridges-title">MTA bridge and tunnel volume: real comparison vs. placebo</title>
    <desc id="bridges-desc">
      Real-window pre vs. post (left pair) declined 1.3%; placebo-window
      (right pair) rose 0.4%. The difference-in-differences is approximately
      −1.75 percentage points.
    </desc>

    <g transform={`translate(${M.left},${M.top})`}>
      {/* Y gridlines + tick labels */}
      {yTicks.map((t) => (
        <g class="grid">
          <line x1={0} x2={innerW} y1={y(t)} y2={y(t)} />
          <text x={-10} y={y(t)} class="tick" text-anchor="end" dominant-baseline="middle">{fmtVal(t)}</text>
        </g>
      ))}

      {/* Bars and labels per group */}
      {groups.map((g) => {
        const gx = groupBand(g.key) ?? 0;
        return (
          <g transform={`translate(${gx},0)`}>
            {/* Pre bar */}
            <g class={`bar bar-${g.key} bar-pre`}>
              <rect
                x={barBand("pre") ?? 0}
                y={y(g.pre.meanPerDay)}
                width={barBand.bandwidth()}
                height={innerH - y(g.pre.meanPerDay)}
                class="bar-fill"
              />
              {/* CI whisker */}
              <line
                x1={(barBand("pre") ?? 0) + barBand.bandwidth() / 2}
                x2={(barBand("pre") ?? 0) + barBand.bandwidth() / 2}
                y1={y(g.pre.ciLo)} y2={y(g.pre.ciHi)}
                class="whisker"
              />
              <text
                x={(barBand("pre") ?? 0) + barBand.bandwidth() / 2}
                y={y(g.pre.meanPerDay) - 6}
                class="bar-value" text-anchor="middle"
              >{fmtVal(g.pre.meanPerDay)}</text>
              <text
                x={(barBand("pre") ?? 0) + barBand.bandwidth() / 2}
                y={innerH + 18}
                class="bar-label" text-anchor="middle"
              >Pre</text>
            </g>
            {/* Post bar */}
            <g class={`bar bar-${g.key} bar-post`}>
              <rect
                x={barBand("post") ?? 0}
                y={y(g.post.meanPerDay)}
                width={barBand.bandwidth()}
                height={innerH - y(g.post.meanPerDay)}
                class="bar-fill"
              />
              <line
                x1={(barBand("post") ?? 0) + barBand.bandwidth() / 2}
                x2={(barBand("post") ?? 0) + barBand.bandwidth() / 2}
                y1={y(g.post.ciLo)} y2={y(g.post.ciHi)}
                class="whisker"
              />
              <text
                x={(barBand("post") ?? 0) + barBand.bandwidth() / 2}
                y={y(g.post.meanPerDay) - 6}
                class="bar-value" text-anchor="middle"
              >{fmtVal(g.post.meanPerDay)}</text>
              <text
                x={(barBand("post") ?? 0) + barBand.bandwidth() / 2}
                y={innerH + 18}
                class="bar-label" text-anchor="middle"
              >Post</text>
            </g>
            {/* Group label and pct change */}
            <text
              x={groupBand.bandwidth() / 2}
              y={innerH + 38}
              class="group-label" text-anchor="middle"
            >{g.label} · {fmtPct(g.pct)}</text>
          </g>
        );
      })}

      {/* Y-axis label */}
      <text
        transform={`translate(${-58},${innerH/2}) rotate(-90)`}
        class="axis-label"
        text-anchor="middle"
      >Vehicles per day</text>
    </g>
  </svg>

  {/* Inline DiD callout */}
  <div class="did-callout">
    <span class="did-label">DiD</span>
    <span class="did-value">{fmtPP(did)}</span>
    <span class="did-note">Real change − placebo change</span>
  </div>
</figure>

<style>
  .bridges-figure {
    margin: var(--s-5) auto;
    max-width: 920px;
  }
  .bridges-figure svg { width: 100%; height: auto; display: block; }

  .grid line {
    stroke: var(--rule);
    stroke-width: 0.5;
    stroke-dasharray: 2 4;
  }
  .tick {
    font-family: var(--font-mono);
    font-size: 12px;
    fill: var(--ink-faint);
    font-feature-settings: "tnum" 1;
  }
  .axis-label {
    font-family: var(--font-mono);
    font-size: 12px;
    fill: var(--ink-faint);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .bar-fill { fill: var(--ink-muted); }
  .bar-real .bar-fill { fill: var(--ink); }
  .bar-placebo .bar-fill { fill: var(--ink-faint); opacity: 0.7; }

  .bar-pre.bar-real .bar-fill,
  .bar-pre.bar-placebo .bar-fill { opacity: 0.55; }

  .whisker {
    stroke: var(--bg);
    stroke-width: 1.5;
    opacity: 0.7;
  }

  .bar-value {
    font-family: var(--font-mono);
    font-size: 13px;
    fill: var(--ink);
    font-feature-settings: "tnum" 1;
  }
  .bar-label {
    font-family: var(--font-mono);
    font-size: 12px;
    fill: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .group-label {
    font-family: var(--font-display);
    font-size: 14px;
    fill: var(--ink);
    font-style: italic;
  }

  .did-callout {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    margin: var(--s-3) auto 0;
    padding: var(--s-2) 0;
    border-top: 1px dotted var(--rule);
    max-width: 420px;
  }
  .did-label {
    font-family: var(--font-mono);
    font-size: var(--t-meta);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .did-value {
    font-family: var(--font-mono);
    font-size: 1.875rem;
    color: var(--improve);
    font-weight: 500;
    font-feature-settings: "tnum" 1;
  }
  .did-note {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--t-small);
    color: var(--ink-muted);
  }
</style>
