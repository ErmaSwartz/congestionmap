---
// Portfolio footer — author, role, date, sources, repo, limitations.
import { BASE } from "@/lib/site";
---
<footer class="site-footer" role="contentinfo">
  <div class="wrap">
    <div class="footer-grid">
      <div class="footer-col">
        <div class="footer-label">Author</div>
        <p>Erma Swartz<br/>M.S. Urban Planning &amp; Design, Columbia GSAPP</p>
      </div>
      <div class="footer-col">
        <div class="footer-label">Date</div>
        <p>Spring 2026 · ASA Final</p>
      </div>
      <div class="footer-col">
        <div class="footer-label">Data sources</div>
        <p>
          Sentinel-5P TROPOMI · NYC TLC · MTA Bridges &amp; Tunnels<br/>
          MTA Daily Ridership · ACS 5-year demographics
        </p>
      </div>
      <div class="footer-col">
        <div class="footer-label">Code</div>
        <p>
          <a href="https://github.com/ErmaSwartz/congestionmap">github.com/ErmaSwartz/congestionmap ↗</a>
        </p>
      </div>
    </div>

    <p class="limitations">
      This analysis measures monthly nitrogen dioxide column density at ~5×3 km satellite
      resolution. It does not measure PM2.5, ozone, indoor exposure, or block-level conditions.
      <a href={`${BASE}/caveats/`}>Full limitations →</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--s-8);
    padding: var(--s-6) 0 var(--s-5);
    background: var(--bg-deep);
    border-top: 1px solid var(--rule);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--s-5);
    padding-bottom: var(--s-4);
    border-bottom: 1px solid var(--rule);
  }
  .footer-col p {
    font-family: var(--font-text);
    font-size: var(--t-small);
    line-height: 1.55;
    color: var(--ink-muted);
    margin: 0;
    text-align: left;
    max-width: none;
  }
  .footer-label {
    font-size: var(--t-meta);
    text-align: left;
  }
  .footer-col a { color: var(--ink); border-bottom: 1px solid var(--rule); }
  .footer-col a:hover { border-color: var(--ink); }
  .footer-label {
    font-family: var(--font-mono);
    font-size: var(--t-meta);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: var(--s-2);
  }
  .limitations {
    font-family: var(--font-text);
    font-style: italic;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ink-muted);
    max-width: 70ch;
    margin: var(--s-4) auto 0;
    text-align: center;
  }
  .limitations a {
    color: var(--ink);
    border-bottom: 1px solid var(--rule);
    font-style: normal;
  }
  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); gap: var(--s-4); }
  }
  @media (max-width: 560px) {
    .footer-grid { grid-template-columns: 1fr; gap: var(--s-3); }
  }
</style>
